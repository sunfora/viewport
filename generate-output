#!/usr/bin/env -S tcc -run
#include <stdbool.h>
#include <stdio.h>
#include <unistd.h>
#include <time.h>

int main() {
  while (true) {
    time_t current_time = time(NULL);
    struct tm *info = localtime(&current_time);

    printf("\e[1J\e[H"); 
    printf(
        "Current Time: %02d:%02d:%02d\n", 
        info->tm_hour, info->tm_min, info->tm_sec
    );

    for (int i = 0; i < 10; ++i) {
      puts(
        "Some very long log" "\n"
        "Some very long log" "\n"
        "Some very long log" "\n"
        "Some very long log" "\n"
        "Some very long log" "\n"
        "Some very long log" "\n"
        "Some very long log" "\n"
        "Some very long log" "\n"
      );
    }

    usleep(200000);
  }
}
